{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/googled352441549b06d7c.html", "destination": "/api/google-verify" },
    { "source": "/googled352441549b06d7c", "destination": "/api/google-verify" }
  ],
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.botlease.nl" }], "destination": "https://botlease.nl/$1", "permanent": true },
    { "source": "/chatbot-landing", "destination": "/", "permanent": true },
    { "source": "/chatbot-landing.html", "destination": "/", "permanent": true },
    { "source": "/chatbot-split", "destination": "/", "permanent": true },
    { "source": "/chatbot-split.html", "destination": "/", "permanent": true },
    { "source": "/chatbot-test", "destination": "/", "permanent": true },
    { "source": "/chatbot-test.html", "destination": "/", "permanent": true },
    { "source": "/index-old", "destination": "/", "permanent": true },
    { "source": "/index-old.html", "destination": "/", "permanent": true },
    { "source": "/index-chatbot-backup", "destination": "/", "permanent": true },
    { "source": "/index-chatbot-backup.html", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|svg|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
